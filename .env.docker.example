# ===== Fluid Scientist Docker 部署环境变量 =====
# 复制此文件为 .env 并填入实际值

# --- 应用配置 ---
FLUID_APP_MODE=fake
APP_PORT=8000

# --- OpenAI 配置（real 模式必需）---
FLUID_OPENAI__API_KEY=
FLUID_OPENAI__PLANNER_MODEL=gpt-5.5
FLUID_OPENAI__EXTRACTOR_MODEL=gpt-5.4-mini

# --- PostgreSQL（可选，默认使用容器内 SQLite）---
POSTGRES_DB=fluid_scientist
POSTGRES_USER=fluid_scientist
POSTGRES_PASSWORD=change-me-in-production
# 启用 PostgreSQL 时设置：
# FLUID_DATABASE__URL=postgresql://fluid_scientist:change-me-in-production@postgres:5432/fluid_scientist

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant 向量数据库 ---
QDRANT_URL=http://qdrant:6333

# --- MinIO 对象存储 ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=local-development
MINIO_SECRET_KEY=change-me-in-production

# --- OpenFOAM 工作站 SSH 配置（real 模式必需）---
# 工作站主机列表，JSON 数组格式，如 ["192.168.1.100"]
FLUID_WORKSTATION__HOSTS=[]
FLUID_WORKSTATION__USERNAME=
FLUID_WORKSTATION__PORT=22
# 容器内 SSH 私钥路径（通过 volume 挂载）
FLUID_WORKSTATION__IDENTITY_FILE=/app/ssh-keys/id_ed25519
FLUID_WORKSTATION__KNOWN_HOSTS_FILE=/app/ssh-keys/known_hosts

# --- SSH 密钥目录（主机侧路径，挂载到容器 /app/ssh-keys）---
SSH_KEYS_DIR=./ssh-keys